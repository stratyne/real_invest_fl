# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://penstock:penstock@localhost:5432/real_invest_fl
SYNC_DATABASE_URL=postgresql+psycopg2://penstock:penstock@localhost:5432/real_invest_fl

# ── Redis / Celery ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Google ───────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-service-account.json
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_WORKSHEET=Qualified Properties
GOOGLE_CALENDAR_ID=primary
GOOGLE_OAUTH_CLIENT_SECRET=./secrets/oauth-client-secret.json
GOOGLE_OAUTH_TOKEN=./secrets/oauth-token.json

# ── Email ─────────────────────────────────────────────────────────────────
EMAIL_MODE=sendgrid
SENDGRID_API_KEY=
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
SENDER_EMAIL=
REPLY_TO_EMAIL=

# ── Outreach ──────────────────────────────────────────────────────────────
ALLOW_AUTOMATED_OUTREACH=false
BOOKING_URL=https://calendly.com/your-handle/15min

# ── Notifications ─────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Zestimate ─────────────────────────────────────────────────────────────
ZESTIMATE_STALENESS_DAYS=7

# ── Proxies ───────────────────────────────────────────────────────────────
USE_PROXIES=false
PROXIES_FILE=./config/proxies.txt

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-before-production-use-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
